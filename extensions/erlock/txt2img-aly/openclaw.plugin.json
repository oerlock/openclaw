{
  "id": "txt2img-aly",
  "name": "Txt2Img Aly",
  "description": "txt2img extension for aly.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
